<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scs.mapper.StudentMapper">

    <resultMap id="StudentResultMap" type="com.scs.entity.Student">
        <id column="id" property="id"/>
        <result column="student_no" property="studentNo"/>
        <result column="student_name" property="studentName"/>
        <result column="password" property="password"/>
        <result column="gender" property="gender"/>
        <result column="birthday" property="birthday"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="clazz_id" property="clazzId"/>
        <result column="enrollment_date" property="enrollmentDate"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="clazz_name" property="clazzName"/>
        <result column="major_name" property="majorName"/>
        <result column="dept_name" property="deptName"/>
    </resultMap>

    <select id="selectStudentPage" resultMap="StudentResultMap">
        SELECT
            s.*,
            c.clazz_name,
            m.major_name,
            d.dept_name
        FROM student s
        LEFT JOIN clazz c ON s.clazz_id = c.id
        LEFT JOIN major m ON c.major_id = m.id
        LEFT JOIN department d ON m.dept_id = d.id
        <where>
            <if test="student.studentNo != null and student.studentNo != ''">
                AND s.student_no LIKE CONCAT('%', #{student.studentNo}, '%')
            </if>
            <if test="student.studentName != null and student.studentName != ''">
                AND s.student_name LIKE CONCAT('%', #{student.studentName}, '%')
            </if>
            <if test="student.clazzId != null">
                AND s.clazz_id = #{student.clazzId}
            </if>
            <if test="student.status != null">
                AND s.status = #{student.status}
            </if>
        </where>
        ORDER BY s.id DESC
    </select>
    <resultMap id="StudentWithClazzResultMap" type="com.scs.entity.Student">
        <id column="id" property="id"/>
        <result column="student_no" property="studentNo"/>
        <result column="student_name" property="studentName"/>
        <result column="password" property="password"/>
        <result column="gender" property="gender"/>
        <result column="birthday" property="birthday"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="clazz_id" property="clazzId"/>
        <result column="enrollment_date" property="enrollmentDate"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="clazz_name" property="clazzName"/>
    </resultMap>

    <select id="selectStudentWithClazz" resultMap="StudentWithClazzResultMap">
        SELECT
            s.*,
            c.clazz_name
        FROM student s
                 LEFT JOIN clazz c ON s.clazz_id = c.id
        WHERE s.id = #{id}
    </select>



</mapper>
